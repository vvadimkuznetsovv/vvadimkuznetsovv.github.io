---
import Shell from "../layouts/Shell.astro";
import PhotoFrame from "../components/PhotoFrame.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<Shell
  title="VADIM KUZNETSOV"
  description="Вадим Кузнецов — full-stack разработчик. Веб, мобильное, игры. Личная база проектов."
  statusLabel="vvadimkuznetsovv"
>
  <!-- HERO -->
  <section class="mt-16 grid grid-cols-1 items-start gap-12 sm:mt-20 md:grid-cols-[300px_minmax(0,1fr)] md:gap-14 lg:grid-cols-[360px_minmax(0,1fr)] lg:gap-20">
    <div class="fade-in fade-in-2 flex justify-center md:justify-start">
      <PhotoFrame label="" caption="" />
    </div>

    <div class="flex flex-col gap-7">
      <h1 class="fade-in fade-in-3 flex flex-col gap-0 leading-none">
        <span class="neon-text neon-text--cyan text-[clamp(3.6rem,14vw,8rem)]">
          Vadim
        </span>
        <span class="neon-text neon-text--magenta text-[clamp(3.6rem,14vw,8rem)] -mt-4">
          Kuznetsov
        </span>
      </h1>

      <p class="fade-in fade-in-4 font-ui text-base uppercase tracking-[0.2em] text-dim">
        full-stack engineer&nbsp;·&nbsp;web&nbsp;·&nbsp;mobile&nbsp;·&nbsp;games
      </p>

      <p class="fade-in fade-in-5 max-w-xl font-ui text-base leading-relaxed text-haze sm:text-lg">
        Строю продукты в вебе, мобильном и играх. Ниже — живые проекты,
        ниже‑ниже — будет полный реестр.
      </p>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="mt-24">
    <div class="flex items-baseline justify-between gap-4 border-b border-rack pb-3">
      <h2 class="font-ui text-sm font-medium uppercase tracking-[0.3em] text-haze sm:text-base">
        Live projects
      </h2>
      <span class="font-ui text-xs uppercase tracking-[0.2em] text-dim">003 entries</span>
    </div>

    <div class="mt-10 flex flex-col gap-7 sm:gap-8">
      <ProjectCard
        index="001"
        title="Traffic Laws"
        status="WIP"
        statusColor="amber"
        href="/traffic-laws/"
      >
        Уникальный сайт изучения ПДД категории B. Подробные объяснения каждого
        правильного и неправильного ответа, разбор картинок билетов, киберпанк‑роман
        со всеми правилами, вшитыми в нарратив.
      </ProjectCard>

      <ProjectCard
        index="002"
        title="vvadimkuznetsovv.github.io"
        status="Live"
        statusColor="toxic"
        href="https://github.com/vvadimkuznetsovv/vvadimkuznetsovv.github.io"
        external
      >
        Этот самый сайт. Astro 5 + Svelte 5 + Tailwind 4. Open source, MIT.
      </ProjectCard>

      <ProjectCard
        index="003"
        title="Portfolio extra"
        status="Loading"
        statusColor="dim"
        disabled
      >
        кондиционеркин23.рф · print.kubstu.ru · proverka-cheka.online ·
        Fearful Obscured Grounds (Steam). Будут перечислены отдельно после релиза
        traffic-laws.
      </ProjectCard>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="mt-24 flex flex-wrap items-center justify-between gap-4 border-t border-rack pt-6 font-ui text-xs uppercase tracking-[0.25em] text-dim">
    <span>{new Date().getFullYear()}</span>
    <div class="flex items-center gap-6">
      <a
        class="text-haze transition-colors hover:text-cyan"
        href="https://github.com/vvadimkuznetsovv"
        rel="noreferrer noopener"
        target="_blank"
      >
        github
      </a>
      <a class="text-haze transition-colors hover:text-cyan" href="/traffic-laws/">
        /traffic-laws
      </a>
    </div>
  </footer>
</Shell>
