---
import Shell from "../layouts/Shell.astro";
import CautionStripe from "../components/CautionStripe.astro";
import PhotoFrame from "../components/PhotoFrame.astro";
import NeonSign from "../components/NeonSign.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<Shell
  title="VADIM KUZNETSOV"
  description="Вадим Кузнецов — full-stack разработчик. Веб, мобильное, игры. Личная база проектов."
  statusLabel="V.NK://personal_db_v0.1"
>
  <div class="fade-in fade-in-1 mt-5">
    <CautionStripe label="// SYS BOOT OK — WELCOME, NETRUNNER" />
  </div>

  <!-- HERO -->
  <section class="mt-10 grid grid-cols-1 items-start gap-12 sm:mt-14 md:grid-cols-[300px_minmax(0,1fr)] md:gap-14 lg:grid-cols-[360px_minmax(0,1fr)] lg:gap-20">
    <div class="fade-in fade-in-2 flex justify-center md:justify-start">
      <PhotoFrame label="AUTH PHOTO :: N/A" caption="ID-734-VK" />
    </div>

    <div class="flex flex-col gap-7">
      <div class="fade-in fade-in-2 flex flex-wrap items-center gap-3">
        <span class="font-hud text-base text-yellow neon-pulse">[REC_ID]</span>
        <span class="font-hud text-base text-haze">V_KUZNETSOV</span>
        <span class="font-hud text-base text-cyan/60">/</span>
        <span class="font-hud text-base text-cyan neon-pulse neon-pulse--cyan">@vvadimkuznetsovv</span>
      </div>

      <h1 class="fade-in fade-in-3 flex flex-col gap-1 leading-none">
        <NeonSign text="VADIM" color="cyan" size="xl" decrypt />
        <NeonSign text="KUZNETSOV" color="cyan" size="xl" decrypt />
      </h1>

      <dl class="fade-in fade-in-4 grid grid-cols-1 gap-1 font-hud text-lg sm:text-xl">
        <div class="grid grid-cols-[110px_1fr] gap-3 sm:grid-cols-[140px_1fr]">
          <dt class="text-dim">&gt; ROLE</dt>
          <dd class="text-haze">full-stack engineer</dd>
        </div>
        <div class="grid grid-cols-[110px_1fr] gap-3 sm:grid-cols-[140px_1fr]">
          <dt class="text-dim">&gt; STACK</dt>
          <dd class="text-haze">web · mobile · games</dd>
        </div>
        <div class="grid grid-cols-[110px_1fr] gap-3 sm:grid-cols-[140px_1fr]">
          <dt class="text-dim">&gt; LOCATION</dt>
          <dd class="text-haze">[REDACTED]</dd>
        </div>
        <div class="grid grid-cols-[110px_1fr] gap-3 sm:grid-cols-[140px_1fr]">
          <dt class="text-dim">&gt; STATUS</dt>
          <dd class="text-toxic neon-pulse" style="--neon-color: var(--color-toxic);">SHIPPING</dd>
        </div>
      </dl>

      <p class="fade-in fade-in-5 max-w-xl font-ui text-base text-haze sm:text-lg">
        строю продукты в вебе, мобильном и играх. ниже&nbsp;— живые проекты,
        ниже‑ниже&nbsp;— будет полный реестр.
      </p>
    </div>
  </section>

  <div class="fade-in fade-in-5 mt-16">
    <CautionStripe label="LIVE PROJECTS // 003 ENTRIES" />
  </div>

  <!-- PROJECTS -->
  <section class="mt-10">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="font-hud text-2xl uppercase tracking-[0.2em] neon-pulse sm:text-3xl">
        &gt; LIVE_PROJECTS
      </h2>
      <span class="font-hud text-base text-dim">[ idx :: 001-003 ]</span>
    </div>

    <div class="mt-10 flex flex-col gap-7 sm:gap-8">
      <ProjectCard
        index="001"
        title="TRAFFIC LAWS"
        status="WIP"
        statusColor="amber"
        href="/traffic-laws/"
      >
        Уникальный сайт изучения ПДД категории B. Подробные объяснения каждого
        правильного и неправильного ответа, разбор картинок билетов, киберпанк‑роман
        со всеми правилами, вшитыми в нарратив.
      </ProjectCard>

      <ProjectCard
        index="002"
        title="vvadimkuznetsovv.github.io"
        status="LIVE"
        statusColor="toxic"
        href="https://github.com/vvadimkuznetsovv/vvadimkuznetsovv.github.io"
        external
      >
        Этот самый сайт. Astro 5 + Svelte 5 + Tailwind 4. Open source, MIT.
      </ProjectCard>

      <ProjectCard
        index="003"
        title="PORTFOLIO_EXTRA"
        status="LOADING"
        statusColor="dim"
        disabled
      >
        кондиционеркин23.рф · print.kubstu.ru · proverka-cheka.online ·
        Fearful Obscured Grounds (Steam). Будут перечислены отдельно после релиза
        traffic-laws.
      </ProjectCard>
    </div>
  </section>

  <div class="fade-in fade-in-5 mt-16">
    <CautionStripe />
  </div>

  <!-- FOOTER -->
  <footer class="mt-10 flex flex-wrap items-center justify-between gap-4 font-hud text-base text-dim">
    <span class="text-haze">// EOL :: {new Date().getFullYear()}</span>
    <div class="flex items-center gap-5">
      <a
        class="text-cyan transition-colors hover:text-yellow neon-pulse neon-pulse--cyan"
        href="https://github.com/vvadimkuznetsovv"
        rel="noreferrer noopener"
        target="_blank"
      >
        &gt; github.com/vvadimkuznetsovv
      </a>
      <span class="text-magenta">●</span>
      <a
        class="text-cyan transition-colors hover:text-yellow"
        href="/traffic-laws/"
      >
        &gt; /traffic-laws
      </a>
    </div>
  </footer>
</Shell>
