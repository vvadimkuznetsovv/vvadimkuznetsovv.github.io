---
import Shell from "../../layouts/Shell.astro";
import CautionStripe from "../../components/CautionStripe.astro";
import NeonSign from "../../components/NeonSign.astro";

const modes = [
  {
    code: "M01",
    title: "ИЗУЧЕНИЕ ПО ТЕМАМ",
    body: "Чтение правил с интерактивными примерами и связанными знаками.",
    state: "QUEUED",
  },
  {
    code: "M02",
    title: "ТРЕНИРОВКА ПО БИЛЕТАМ",
    body: "20 вопросов с объяснением каждого правильного и неправильного ответа.",
    state: "QUEUED",
  },
  {
    code: "M03",
    title: "ЭКЗАМЕН НА ВРЕМЯ",
    body: "Правила ГИБДД: 20 вопросов, 20 минут, ≤ 2 ошибки.",
    state: "QUEUED",
  },
  {
    code: "M04",
    title: "СПРАВОЧНИК ЗНАКОВ",
    body: "Поиск, фильтр по группам, типичные ошибки восприятия.",
    state: "QUEUED",
  },
] as const;
---

<Shell
  title="ПДД :: traffic-laws"
  description="Уникальный сайт изучения ПДД категории B: подробные объяснения, разбор картинок, киберпанк-роман со всеми правилами."
  statusLabel="V.NK://traffic_laws_v0.1"
>
  <nav class="mt-5 flex items-center gap-4 font-hud text-base">
    <a
      href="/"
      class="text-cyan transition-colors hover:text-yellow neon-pulse neon-pulse--cyan"
      >&lt;- back to vvadimkuznetsovv</a
    >
  </nav>

  <div class="fade-in fade-in-1 mt-6">
    <CautionStripe label="// MODULE :: TRAFFIC_LAWS_RU // CATEGORY :: B" />
  </div>

  <!-- HERO -->
  <header class="fade-in fade-in-2 mt-12 sm:mt-16">
    <p class="font-hud text-lg neon-pulse sm:text-xl">
      &gt; build #001 :: skeleton phase
    </p>
    <h1 class="mt-4 flex flex-col gap-1 leading-none">
      <NeonSign text="TRAFFIC" color="cyan" size="lg" decrypt />
      <NeonSign text="LAWS" color="magenta" size="lg" decrypt />
    </h1>
    <p class="mt-6 max-w-2xl font-ui text-base text-haze sm:text-lg">
      Изучение правил дорожного движения категории B в формате in‑world терминала.
      Подробные объяснения, разбор картинок билетов, киберпанк‑роман со всеми
      правилами, вшитыми в нарратив.
    </p>
  </header>

  <div class="fade-in fade-in-3 mt-16">
    <CautionStripe label="MODES // 005 ENTRIES" />
  </div>

  <!-- MODES -->
  <section class="mt-10">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="font-hud text-2xl uppercase tracking-[0.2em] neon-pulse sm:text-3xl">
        &gt; MODES
      </h2>
      <span class="font-hud text-base text-dim">[ idx :: M01-M05 ]</span>
    </div>

    <ul class="mt-10 grid gap-7 sm:grid-cols-2 sm:gap-8">
      {
        modes.map((mode) => (
          <li class="notched notched--dim" style="--notch: 22px;">
            <div class="notched__body">
              <span class="notched__edge" aria-hidden="true" />
              <span class="notched__chevrons" aria-hidden="true" />

              <div class="flex items-center justify-between gap-3">
                <span class="font-hud text-base text-yellow drop-shadow-[0_0_6px_var(--color-yellow)]">
                  [ {mode.code} ]
                </span>
                <span class="font-hud text-base text-dim">[ {mode.state} ]</span>
              </div>

              <h3 class="mt-2 font-ui text-base font-bold uppercase tracking-[0.08em] text-bone sm:text-lg">
                {mode.title}
              </h3>

              <p class="mt-2 font-ui text-sm leading-relaxed text-haze sm:text-base">
                {mode.body}
              </p>
            </div>
          </li>
        ))
      }

      <!-- Signature mode: cyberpunk novel -->
      <li class="notched notched--magenta sm:col-span-2" style="--notch: 28px;">
        <div class="notched__body">
          <span class="notched__edge" aria-hidden="true"></span>
          <span class="notched__chevrons" aria-hidden="true"></span>

          <div class="flex flex-wrap items-center justify-between gap-3">
            <span class="font-hud text-base text-magenta neon-pulse neon-pulse--magenta">
              [ M05 :: SIGNATURE_MODE ]
            </span>
            <span class="font-hud text-base text-pink">[ QUEUED ]</span>
          </div>

          <h3 class="mt-3 font-ui text-xl font-bold uppercase tracking-[0.08em] text-bone sm:text-3xl">
            киберпанк‑роман
          </h3>

          <p class="mt-3 max-w-3xl font-ui text-sm leading-relaxed text-haze sm:text-base">
            Интерактивный роман со всеми правилами ПДД, вшитыми в нарратив через мысли
            героев, выборы и анимированные SVG‑сцены дорожных ситуаций. Главная фишка
            проекта — никаких сухих формулировок, всё через сюжет.
          </p>
        </div>
      </li>
    </ul>
  </section>

  <div class="fade-in fade-in-3 mt-16">
    <CautionStripe />
  </div>

  <!-- STATUS -->
  <section class="mt-10 grid gap-6 sm:grid-cols-2">
    <div class="notched" style="--notch: 18px;">
      <div class="notched__body">
        <span class="notched__edge" aria-hidden="true"></span>
        <p class="font-hud text-base neon-pulse neon-pulse--cyan">// build_status</p>
        <p class="mt-3 font-ui text-base text-haze">
          Phase 0: <span class="text-toxic neon-pulse" style="--neon-color: var(--color-toxic);">DONE</span> · скелет в проде.
        </p>
        <p class="mt-1 font-ui text-base text-haze">
          Phase 1.1: <span class="text-toxic neon-pulse" style="--neon-color: var(--color-toxic);">DONE</span> · Astro+Svelte+Tailwind+MDX.
        </p>
        <p class="mt-1 font-ui text-base text-haze">
          Phase 1.2: <span class="text-toxic neon-pulse" style="--neon-color: var(--color-toxic);">DONE</span> · CP2077 design system.
        </p>
        <p class="mt-1 font-ui text-base text-haze">
          Phase 1.3: <span class="text-amber">NEXT</span> · open dataset ПДД + знаки.
        </p>
      </div>
    </div>

    <div class="notched" style="--notch: 18px; --border-color: var(--color-yellow); --glow-1: rgba(252,238,10,0.45); --glow-2: rgba(252,238,10,0.18);">
      <div class="notched__body">
        <span class="notched__edge" aria-hidden="true" style="background: var(--color-yellow); box-shadow: 0 0 6px var(--color-yellow), 0 0 14px var(--color-yellow);"></span>
        <p class="font-hud text-base neon-pulse">// up_next</p>
        <ul class="mt-2 space-y-1 font-ui text-base text-haze">
          <li>· импорт open dataset вопросов</li>
          <li>· каталог знаков (SVG, Wikimedia)</li>
          <li>· quiz UX с разбором каждого ответа</li>
          <li>· экзамен‑режим с таймером</li>
          <li>· POC главы романа</li>
        </ul>
      </div>
    </div>
  </section>

  <footer class="mt-16 flex flex-wrap items-center justify-between gap-4 font-hud text-base text-dim">
    <span class="text-haze">// MODULE_END</span>
    <a class="text-cyan transition-colors hover:text-yellow neon-pulse neon-pulse--cyan" href="/">
      &lt;- back to root
    </a>
  </footer>
</Shell>
