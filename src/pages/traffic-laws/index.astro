---
import Shell from "../../layouts/Shell.astro";

const modes = [
  {
    title: "Изучение по темам",
    body: "Чтение правил с интерактивными примерами и связанными знаками.",
    state: "Queued",
    href: null,
  },
  {
    title: "Тренировка по билетам",
    body: "40 билетов, 800 вопросов, объяснение каждого правильного и неправильного ответа.",
    state: "Live",
    href: "/traffic-laws/practice/",
  },
  {
    title: "Экзамен на время",
    body: "Правила ГИБДД: 20 вопросов из случайного билета, 20 минут, ≤ 2 ошибки, доп. вопросы за каждую ошибку.",
    state: "Live",
    href: "/traffic-laws/exam/",
  },
  {
    title: "Справочник знаков",
    body: "277 знаков, 8 категорий, подробное описание + действия + штрафы по КоАП.",
    state: "Live",
    href: "/traffic-laws/signs/",
  },
] as const;
---

<Shell
  title="Traffic Laws"
  description="Уникальный сайт изучения ПДД категории B: подробные объяснения, разбор картинок, киберпанк-роман со всеми правилами."
  statusLabel="traffic-laws"
>
  <nav class="mt-5">
    <a
      href="/"
      class="font-ui text-xs uppercase tracking-[0.25em] text-dim transition-colors hover:text-cyan"
      >← vvadimkuznetsovv</a
    >
  </nav>

  <!-- HERO -->
  <header class="fade-in fade-in-2 mt-20 grid grid-cols-1 items-center gap-8 sm:mt-24 md:grid-cols-[auto_minmax(0,1fr)] md:gap-6 lg:gap-8">
    <!-- LOGO: neon traffic light -->
    <div class="mx-auto md:mx-0">
      <svg
        viewBox="0 0 120 320"
        class="traffic-light h-[200px] w-auto md:h-[240px] lg:h-[280px]"
        role="img"
        aria-label="Cyberpunk traffic light"
      >
        <defs>
          <filter id="tl-glow-r" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="6"/>
          </filter>
          <filter id="tl-glow-a" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="6"/>
          </filter>
          <filter id="tl-glow-g" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="6"/>
          </filter>
        </defs>
        <rect x="10" y="0" width="100" height="320" rx="14"
          fill="#0a0a18" stroke="#1c1c30" stroke-width="2" />
        <rect x="15" y="5" width="90" height="310" rx="10"
          fill="none" stroke="#22253a" stroke-width="1" />
        <g class="traffic-light__lamp">
          <circle cx="60" cy="60" r="36" fill="#ff003c" opacity="0.6" filter="url(#tl-glow-r)"/>
          <circle cx="60" cy="60" r="28" fill="#ff003c"/>
          <circle cx="60" cy="60" r="20" fill="#ff5777"/>
          <circle cx="60" cy="60" r="10" fill="#ffd0db"/>
        </g>
        <g class="traffic-light__lamp" opacity="0.3">
          <circle cx="60" cy="160" r="36" fill="#ff8a00" opacity="0.6" filter="url(#tl-glow-a)"/>
          <circle cx="60" cy="160" r="28" fill="#ff8a00"/>
          <circle cx="60" cy="160" r="20" fill="#ffb142"/>
          <circle cx="60" cy="160" r="10" fill="#ffe4be"/>
        </g>
        <g class="traffic-light__lamp">
          <circle cx="60" cy="260" r="36" fill="#00ff9c" opacity="0.6" filter="url(#tl-glow-g)"/>
          <circle cx="60" cy="260" r="28" fill="#00ff9c"/>
          <circle cx="60" cy="260" r="20" fill="#74ffc4"/>
          <circle cx="60" cy="260" r="10" fill="#d4ffec"/>
        </g>
      </svg>
    </div>

    <!-- TEXT -->
    <div class="min-w-0">
      <h1 class="flex flex-col gap-2 leading-none">
        <span class="neon-text neon-text--cyan text-[clamp(2.6rem,10vw,6rem)]">
          TRAFFIC
        </span>
        <span class="neon-text neon-text--magenta text-[clamp(2.6rem,10vw,6rem)]">
          LAWS
        </span>
      </h1>
      <p class="mt-8 max-w-2xl font-ui text-base leading-relaxed text-haze sm:text-lg">
        Изучение правил дорожного движения категории B в формате in‑world терминала.
        Подробные объяснения, разбор картинок билетов, киберпанк‑роман со всеми
        правилами, вшитыми в нарратив.
      </p>
    </div>
  </header>

  <!-- MODES -->
  <section class="mt-24">
    <div class="flex items-baseline justify-between gap-4 border-b border-rack pb-3">
      <h2 class="font-ui text-sm font-medium uppercase tracking-[0.3em] text-haze sm:text-base">
        Modes
      </h2>
      <span class="font-ui text-xs uppercase tracking-[0.2em] text-dim">005 entries</span>
    </div>

    <ul class="mt-10 grid gap-5 sm:grid-cols-2 sm:gap-6">
      {
        modes.map((mode) => {
          const isLive = mode.state === "Live" && mode.href;
          const Tag = isLive ? "a" : "div";
          return (
            <li>
              <Tag
                href={isLive ? mode.href : undefined}
                class:list={[
                  "group relative block border bg-deck p-6 transition-colors",
                  isLive
                    ? "border-rack hover:border-cyan/70"
                    : "border-rack opacity-70",
                ]}
              >
                <span
                  class:list={[
                    "absolute left-0 top-6 bottom-6 w-px transition-colors",
                    isLive ? "bg-cyan/40 group-hover:bg-cyan" : "bg-dim/30",
                  ]}
                  aria-hidden="true"
                />
                <div class="flex items-center justify-between gap-3">
                  <span
                    class:list={[
                      "font-ui text-xs uppercase tracking-[0.25em]",
                      isLive ? "text-toxic" : "text-dim",
                    ]}
                  >
                    {mode.state}
                  </span>
                  {isLive && (
                    <span class="font-hud text-base text-cyan transition-transform group-hover:translate-x-1">
                      → open
                    </span>
                  )}
                </div>
                <h3 class="mt-3 font-ui text-lg font-medium text-bone sm:text-xl">
                  {mode.title}
                </h3>
                <p class="mt-2 font-ui text-sm leading-relaxed text-haze sm:text-base">
                  {mode.body}
                </p>
              </Tag>
            </li>
          );
        })
      }

      <!-- Signature: cyberpunk novel -->
      <li class="relative border border-magenta/60 bg-deck p-6 sm:col-span-2">
        <span class="absolute left-0 top-6 bottom-6 w-px bg-magenta" aria-hidden="true" />
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span class="font-ui text-xs uppercase tracking-[0.25em] text-magenta">Signature mode · queued</span>
        </div>
        <h3 class="mt-3 font-ui text-xl font-medium text-bone sm:text-2xl">
          Киберпанк-роман
        </h3>
        <p class="mt-3 max-w-3xl font-ui text-sm leading-relaxed text-haze sm:text-base">
          Интерактивный роман со всеми правилами ПДД, вшитыми в нарратив через мысли
          героев, выборы и анимированные SVG‑сцены дорожных ситуаций. Главная фишка
          проекта — никаких сухих формулировок, всё через сюжет.
        </p>
      </li>
    </ul>
  </section>

  <footer class="mt-24 flex flex-wrap items-center justify-between gap-4 border-t border-rack pt-6 font-ui text-xs uppercase tracking-[0.25em] text-dim">
    <span>module_end</span>
    <a class="text-haze transition-colors hover:text-cyan" href="/">← root</a>
  </footer>
</Shell>
