---
import Shell from "../../../../layouts/Shell.astro";
import {
  getAllSignsFlat,
  getSignByNumber,
  signSlug,
  signFromSlug,
} from "../../../../data/pdd";

export function getStaticPaths() {
  return getAllSignsFlat().map(({ sign }) => ({
    params: { id: signSlug(sign.number) },
  }));
}

const { id } = Astro.params;
const result = id ? getSignByNumber(signFromSlug(id)) : undefined;

if (!result) {
  return Astro.redirect("/traffic-laws/signs/");
}

const { category, sign } = result;

// Pull other signs in the same category for "соседи" navigation
const all = getAllSignsFlat();
const sameCat = all.filter((s) => s.category === category).map((s) => s.sign);
const idx = sameCat.findIndex((s) => s.number === sign.number);
const prev = idx > 0 ? sameCat[idx - 1] : null;
const next = idx < sameCat.length - 1 ? sameCat[idx + 1] : null;
---

<Shell
  title={`${sign.number} ${sign.title} — TRAFFIC LAWS`}
  description={`${sign.title}. ${(sign.description ?? "").slice(0, 160)}`}
  statusLabel={`traffic-laws/signs/${sign.number}`}
>
  <nav class="mt-5 flex flex-wrap items-center gap-4 font-ui text-xs uppercase tracking-[0.25em] text-dim">
    <a href="/traffic-laws/" class="transition-colors hover:text-cyan">← traffic-laws</a>
    <span class="text-dim/50">/</span>
    <a href="/traffic-laws/signs/" class="transition-colors hover:text-cyan">signs</a>
    <span class="text-dim/50">/</span>
    <span class="text-haze">{sign.number}</span>
  </nav>

  <header class="fade-in fade-in-2 mt-12 grid grid-cols-1 items-start gap-10 sm:mt-16 md:grid-cols-[260px_minmax(0,1fr)] md:gap-12 lg:grid-cols-[320px_minmax(0,1fr)] lg:gap-16">
    <div class="mx-auto md:mx-0">
      <div class="relative border border-cyan/40 bg-deck p-6 sm:p-8">
        <span
          class="absolute left-0 top-6 bottom-6 w-px bg-cyan"
          aria-hidden="true"
        />
        <img
          src={sign.image}
          alt={sign.title}
          class="block h-auto w-full max-w-[220px] object-contain"
        />
      </div>
      <p class="mt-4 text-center font-hud text-base uppercase tracking-[0.3em] text-cyan">
        {sign.number}
      </p>
    </div>

    <div>
      <p class="font-ui text-xs uppercase tracking-[0.3em] text-dim">
        {category}
      </p>
      <h1 class="mt-4 font-ui text-2xl font-medium leading-tight text-bone sm:text-3xl md:text-4xl">
        {sign.title}
      </h1>

      {sign.description && (
        <div class="mt-8 border-l-2 border-cyan/60 bg-cyan/5 px-5 py-4">
          <p class="font-hud text-base uppercase tracking-[0.2em] text-cyan">
            // описание · действие · штрафы
          </p>
          <p class="mt-3 whitespace-pre-line font-ui text-sm leading-relaxed text-haze sm:text-base">
            {sign.description}
          </p>
        </div>
      )}

      {!sign.description && (
        <p class="mt-8 font-ui text-sm text-dim">
          Описание для этого знака пока не подгружено.
        </p>
      )}
    </div>
  </header>

  <footer class="mt-20 flex flex-wrap items-center justify-between gap-6 border-t border-rack pt-6 font-ui text-xs uppercase tracking-[0.25em]">
    {
      prev ? (
        <a
          href={`/traffic-laws/signs/${signSlug(prev.number)}/`}
          class="flex items-center gap-3 text-haze transition-colors hover:text-cyan"
        >
          <span class="text-dim">←</span>
          <span>{prev.number} {prev.title}</span>
        </a>
      ) : (
        <a
          href="/traffic-laws/signs/"
          class="flex items-center gap-3 text-haze transition-colors hover:text-cyan"
        >
          <span class="text-dim">←</span>
          <span>все знаки</span>
        </a>
      )
    }
    {
      next && (
        <a
          href={`/traffic-laws/signs/${signSlug(next.number)}/`}
          class="ml-auto flex items-center gap-3 text-haze transition-colors hover:text-cyan"
        >
          <span>{next.number} {next.title}</span>
          <span class="text-dim">→</span>
        </a>
      )
    }
  </footer>
</Shell>
