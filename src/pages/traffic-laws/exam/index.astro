---
import Shell from "../../../layouts/Shell.astro";
import ModeNav from "../../../components/traffic-laws/ModeNav.astro";
import Exam from "../../../components/quiz/Exam.svelte";
import { getAllQuestionsFlat } from "../../../data/pdd";

const pool = getAllQuestionsFlat();
---

<Shell
  title="Экзамен — TRAFFIC LAWS"
  description="Экзамен ПДД по правилам ГИБДД: 20 вопросов из случайного билета, 20 минут, ≤2 ошибки. Дополнительные вопросы за каждую ошибку."
  statusLabel="traffic-laws/exam"
>
  <ModeNav />

  <header class="fade-in fade-in-2 mt-14 sm:mt-20">
    <h1 class="flex flex-col gap-2 leading-none">
      <span class="neon-text neon-text--magenta text-[clamp(2.2rem,8vw,4.5rem)]">
        EXAM
      </span>
    </h1>
    <p class="mt-8 max-w-2xl font-ui text-base leading-relaxed text-haze sm:text-lg">
      Экзамен по правилам ГИБДД. Случайный билет, ограниченное время, ≤ 2 ошибки.
      За каждую ошибку — +5 дополнительных вопросов по той же теме и +5 минут.
      Третья ошибка — провал.
    </p>
  </header>

  <section class="mt-12">
    <Exam pool={pool} client:load />
  </section>
</Shell>
