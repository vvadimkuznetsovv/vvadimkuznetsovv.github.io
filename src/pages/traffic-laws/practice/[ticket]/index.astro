---
import Shell from "../../../../layouts/Shell.astro";
import ModeNav from "../../../../components/traffic-laws/ModeNav.astro";
import QuizSession from "../../../../components/quiz/QuizSession.svelte";
import { getAllTicketNumbers, getTicket } from "../../../../data/pdd";

export function getStaticPaths() {
  return getAllTicketNumbers().map((n) => ({ params: { ticket: String(n) } }));
}

const { ticket } = Astro.params;
const num = Number.parseInt(ticket ?? "0", 10);
const questions = getTicket(num);

if (!questions) {
  return Astro.redirect("/traffic-laws/practice/");
}
---

<Shell
  title={`Билет ${num} — TRAFFIC LAWS`}
  description={`Экзаменационный билет ${num} ПДД категории B: 20 вопросов с подробным разбором.`}
  statusLabel={`traffic-laws/practice/${num}`}
>
  <ModeNav />

  <nav class="mt-8 flex flex-wrap items-center gap-4 font-ui text-xs uppercase tracking-[0.25em] text-dim">
    <a href="/traffic-laws/" class="transition-colors hover:text-cyan">← traffic-laws</a>
    <span class="text-dim/50">/</span>
    <a href="/traffic-laws/practice/" class="transition-colors hover:text-cyan">practice</a>
    <span class="text-dim/50">/</span>
    <span class="text-haze">билет {num}</span>
  </nav>

  <header class="fade-in fade-in-2 mt-16 flex flex-col items-baseline gap-4 sm:flex-row sm:items-end sm:justify-between">
    <h1 class="flex items-baseline gap-4 leading-none">
      <span class="font-hud text-2xl uppercase tracking-[0.2em] text-cyan">
        Билет
      </span>
      <span class="neon-text neon-text--cyan text-[clamp(2.8rem,8vw,5rem)]">
        {num.toString().padStart(2, "0")}
      </span>
    </h1>
    <p class="font-ui text-sm text-dim">
      {questions.length} вопросов · категория AB
    </p>
  </header>

  <section class="mt-12">
    <QuizSession questions={questions} client:load />
  </section>

  <footer class="mt-20 flex flex-wrap items-center justify-between gap-4 border-t border-rack pt-6 font-ui text-xs uppercase tracking-[0.25em] text-dim">
    <a href="/traffic-laws/practice/" class="text-haze transition-colors hover:text-cyan">
      ← все билеты
    </a>
    {num < 40 && (
      <a
        href={`/traffic-laws/practice/${num + 1}/`}
        class="text-haze transition-colors hover:text-cyan"
      >
        билет {num + 1} →
      </a>
    )}
  </footer>
</Shell>
