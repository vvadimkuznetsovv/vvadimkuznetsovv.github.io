---
import Shell from "../../../layouts/Shell.astro";
import ModeNav from "../../../components/traffic-laws/ModeNav.astro";
import HudFrame from "../../../components/ui/HudFrame.astro";
import {
  getAllTicketNumbers,
  getTicketSummary,
  getHardQuestions,
} from "../../../data/pdd";

const tickets = getAllTicketNumbers().map(getTicketSummary);
const totalQuestions = tickets.reduce((sum, t) => sum + t.questionCount, 0);
const hardCount = getHardQuestions().length;
---

<Shell
  title="Тренировка — TRAFFIC LAWS"
  description="40 экзаменационных билетов ПДД категории B с подробным разбором каждого ответа."
  statusLabel="traffic-laws/practice"
>
  <ModeNav />

  <header class="fade-in fade-in-2 mt-14 sm:mt-20">
    <h1 class="flex flex-col gap-2 leading-none">
      <span class="neon-text neon-text--cyan text-[clamp(2.2rem,8vw,4.5rem)]">
        PRACTICE
      </span>
    </h1>
    <p class="mt-8 max-w-2xl font-ui text-base leading-relaxed text-haze sm:text-lg">
      {tickets.length} билетов · {totalQuestions} вопросов · категория AB.
      Каждый билет — 20 вопросов с подробным разбором каждого ответа.
    </p>
  </header>

  <!-- Quick start actions -->
  <section class="fade-in fade-in-3 mt-12">
    <p class="mb-3 font-hud text-base uppercase tracking-[0.25em] text-yellow">
      &gt; быстрый старт
    </p>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
      <HudFrame
        as="a"
        href="/traffic-laws/practice/random/"
        variant="cyber"
        color="cyan"
        class="quick-action block"
      >
        <div class="flex items-baseline justify-between gap-3">
          <span class="font-hud text-base uppercase tracking-[0.2em] text-yellow">
            ⚂ Случайные
          </span>
          <span class="font-hud text-base text-cyan">→ старт</span>
        </div>
        <h2 class="mt-2 font-ui text-xl font-semibold text-bone sm:text-2xl">
          20 случайных вопросов
        </h2>
        <p class="mt-2 font-ui text-sm text-haze">
          Случайная подборка из всех {totalQuestions} вопросов. Можно
          перегенерить и пройти ещё раз.
        </p>
      </HudFrame>

      <HudFrame
        as="a"
        href="/traffic-laws/practice/hard/"
        variant="cyber"
        color="magenta"
        class="quick-action block"
      >
        <div class="flex items-baseline justify-between gap-3">
          <span class="font-hud text-base uppercase tracking-[0.2em] text-pink">
            ⚠ Сложные
          </span>
          <span class="font-hud text-base text-magenta">→ старт</span>
        </div>
        <h2 class="mt-2 font-ui text-xl font-semibold text-bone sm:text-2xl">
          100 самых сложных
        </h2>
        <p class="mt-2 font-ui text-sm text-haze">
          Куратор pddmaster.ru на основе статистики ошибок миллионов прохождений.
          Эти вопросы валят чаще всего.
        </p>
      </HudFrame>
    </div>
  </section>

  <!-- Сетка билетов -->
  <section class="mt-14">
    <p class="mb-3 font-hud text-base uppercase tracking-[0.25em] text-cyan">
      &gt; все билеты · {tickets.length.toString().padStart(2, "0")}
    </p>
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 md:grid-cols-4 lg:grid-cols-5">
      {
        tickets.map((t) => (
          <li>
            <HudFrame
              as="a"
              href={`/traffic-laws/practice/${t.number}/`}
              variant="simple"
              color="cyan"
              class="ticket-tile block"
            >
              <span class="font-hud text-base uppercase tracking-[0.2em] text-dim">
                Билет
              </span>
              <p class="mt-1 font-ui text-3xl font-medium leading-none text-bone sm:text-4xl">
                {t.number.toString().padStart(2, "0")}
              </p>
              <p class="mt-3 font-ui text-xs text-dim">
                {t.questionCount} вопросов
              </p>
            </HudFrame>
          </li>
        ))
      }
    </ul>
  </section>
</Shell>
