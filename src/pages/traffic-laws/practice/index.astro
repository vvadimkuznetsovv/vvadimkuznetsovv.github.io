---
import Shell from "../../../layouts/Shell.astro";
import { getAllTicketNumbers, getTicketSummary } from "../../../data/pdd";

const tickets = getAllTicketNumbers().map(getTicketSummary);
const totalQuestions = tickets.reduce((sum, t) => sum + t.questionCount, 0);
---

<Shell
  title="Тренировка — TRAFFIC LAWS"
  description="40 экзаменационных билетов ПДД категории B с подробным разбором каждого ответа."
  statusLabel="traffic-laws/practice"
>
  <nav class="mt-5">
    <a
      href="/traffic-laws/"
      class="font-ui text-xs uppercase tracking-[0.25em] text-dim transition-colors hover:text-cyan"
      >← traffic-laws</a
    >
  </nav>

  <header class="fade-in fade-in-2 mt-16 sm:mt-20">
    <h1 class="flex flex-col gap-2 leading-none">
      <span class="neon-text neon-text--cyan text-[clamp(2.2rem,8vw,4.5rem)]">
        PRACTICE
      </span>
    </h1>
    <p class="mt-8 max-w-2xl font-ui text-base leading-relaxed text-haze sm:text-lg">
      {tickets.length} билетов · {totalQuestions} вопросов · категория AB.
      Каждый билет — 20 вопросов с подробным разбором каждого ответа.
    </p>
  </header>

  <!-- TABS -->
  <div class="fade-in fade-in-3 mt-14">
    <div class="cy-tabs">
      <a href="/traffic-laws/practice/" class="cy-tab cy-tab--active">
        <span class="cy-tab__icon" aria-hidden="true">▦</span>
        <span class="cy-tab__label">
          <span>Билеты</span>
          <span class="cy-tab__count">{tickets.length.toString().padStart(2, "0")}</span>
        </span>
      </a>
      <a href="#" class="cy-tab cy-tab--disabled" tabindex="-1" aria-disabled="true">
        <span class="cy-tab__icon" aria-hidden="true">▩</span>
        <span class="cy-tab__label">
          <span>Темы</span>
          <span class="cy-tab__count">queued</span>
        </span>
      </a>
      <a href="#" class="cy-tab cy-tab--disabled" tabindex="-1" aria-disabled="true">
        <span class="cy-tab__icon" aria-hidden="true">⚠</span>
        <span class="cy-tab__label">
          <span>Сложные</span>
          <span class="cy-tab__count">queued</span>
        </span>
      </a>
      <a href="#" class="cy-tab cy-tab--disabled" tabindex="-1" aria-disabled="true">
        <span class="cy-tab__icon" aria-hidden="true">⚂</span>
        <span class="cy-tab__label">
          <span>Случайно</span>
          <span class="cy-tab__count">queued</span>
        </span>
      </a>
    </div>
  </div>

  <section class="mt-12">

    <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 md:grid-cols-4 lg:grid-cols-5">
      {
        tickets.map((t) => (
          <li>
            <a
              href={`/traffic-laws/practice/${t.number}/`}
              class="ticket-tile group relative block border border-rack bg-deck px-4 py-5 transition-colors hover:border-cyan/70"
            >
              <span
                class="absolute left-0 top-4 bottom-4 w-px bg-cyan/30 transition-colors group-hover:bg-cyan"
                aria-hidden="true"
              />
              <span class="font-hud text-base uppercase tracking-[0.2em] text-dim">
                Билет
              </span>
              <p class="mt-1 font-ui text-3xl font-medium leading-none text-bone sm:text-4xl">
                {t.number.toString().padStart(2, "0")}
              </p>
              <p class="mt-3 font-ui text-xs text-dim">
                {t.questionCount} вопросов
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Shell>
