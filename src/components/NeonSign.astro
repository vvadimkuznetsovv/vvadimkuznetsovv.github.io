---
type Color = "cyan" | "magenta" | "yellow" | "pink" | "toxic";
type Size = "lg" | "xl" | "2xl";

interface Props {
  text: string;
  color?: Color;
  size?: Size;
  class?: string;
  flicker?: boolean;
}

const {
  text,
  color = "cyan",
  size = "xl",
  class: className = "",
  flicker = true,
} = Astro.props;

const colorMap: Record<Color, string> = {
  cyan: "#00f0ff",
  magenta: "#ff2bd6",
  yellow: "#fcee0a",
  pink: "#ff1f5a",
  toxic: "#00ff9c",
};

const colorHex = colorMap[color];

// SVG viewBox proportional to text length
const fontSize = 140;
const charW = fontSize * 0.58;
const padX = 100;
const padY = 80;
const w = Math.round(Math.max(text.length * charW + padX * 2, 500));
const h = fontSize + padY * 2;

// Unique id (multiple signs per page)
const id = text.toLowerCase().replace(/[^a-z0-9]/g, "").slice(0, 8) + Math.floor(Math.random() * 9999);

const sizeMaxW: Record<Size, string> = {
  lg: "480px",
  xl: "640px",
  "2xl": "820px",
};
---

<svg
  class:list={["neon-sign", flicker && "neon-sign--flicker", className]}
  viewBox={`0 0 ${w} ${h}`}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label={text}
  style={`--neon-max-w: ${sizeMaxW[size]};`}
>
  <defs>
    <!-- Outer soft halo (huge blur) -->
    <filter id={`halo-${id}`} x="-50%" y="-100%" width="200%" height="300%">
      <feGaussianBlur stdDeviation="22"/>
    </filter>
    <!-- Medium halo -->
    <filter id={`mid-${id}`} x="-30%" y="-60%" width="160%" height="220%">
      <feGaussianBlur stdDeviation="8"/>
    </filter>
    <!-- Tight glow around the tube -->
    <filter id={`tight-${id}`} x="-15%" y="-40%" width="130%" height="180%">
      <feGaussianBlur stdDeviation="2.4"/>
    </filter>
    <!-- Inner glass overexposure -->
    <filter id={`core-${id}`} x="-10%" y="-20%" width="120%" height="140%">
      <feGaussianBlur stdDeviation="0.6"/>
    </filter>
  </defs>

  <!-- 1. Outermost halo (large soft glow) -->
  <text
    x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
    font-family="Monoton, 'Major Mono Display', monospace"
    font-size={fontSize}
    fill={colorHex}
    filter={`url(#halo-${id})`}
    opacity="0.9"
    class="neon-sign__layer neon-sign__layer--halo"
  >{text}</text>

  <!-- 2. Medium halo -->
  <text
    x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
    font-family="Monoton, 'Major Mono Display', monospace"
    font-size={fontSize}
    fill={colorHex}
    filter={`url(#mid-${id})`}
    class="neon-sign__layer neon-sign__layer--mid"
  >{text}</text>

  <!-- 3. Tight halo just around the tube -->
  <text
    x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
    font-family="Monoton, 'Major Mono Display', monospace"
    font-size={fontSize}
    fill={colorHex}
    filter={`url(#tight-${id})`}
    class="neon-sign__layer neon-sign__layer--tight"
  >{text}</text>

  <!-- 4. White-hot glass core (the visible tube interior) -->
  <text
    x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
    font-family="Monoton, 'Major Mono Display', monospace"
    font-size={fontSize}
    fill="#ffffff"
    filter={`url(#core-${id})`}
    class="neon-sign__layer neon-sign__layer--core"
  >{text}</text>
</svg>

<style>
  .neon-sign {
    display: block;
    width: 100%;
    height: auto;
    max-width: var(--neon-max-w, 640px);
    overflow: visible;
  }

  /* Rare, realistic tube flicker — like a real neon "trying to ignite" stutter */
  .neon-sign--flicker .neon-sign__layer {
    animation: tube-flicker 14s infinite steps(1, end);
    transform-origin: center;
  }

  @keyframes tube-flicker {
    0%, 84%, 85.5%, 86.5%, 87.5%, 88.8%, 100% { opacity: 1; }
    85%   { opacity: 0.18; }
    86%   { opacity: 0.85; }
    87%   { opacity: 0.25; }
    88%   { opacity: 0.7; }
  }

  /* Slight breathing pulse on the halo layer for "alive gas" */
  .neon-sign__layer--halo {
    animation: halo-breathe 3.5s ease-in-out infinite alternate;
  }
  @keyframes halo-breathe {
    from { opacity: 0.7; }
    to   { opacity: 1; }
  }
  .neon-sign--flicker .neon-sign__layer--halo {
    animation:
      halo-breathe 3.5s ease-in-out infinite alternate,
      tube-flicker 14s infinite steps(1, end);
  }

  @media (prefers-reduced-motion: reduce) {
    .neon-sign__layer { animation: none !important; }
  }
</style>
