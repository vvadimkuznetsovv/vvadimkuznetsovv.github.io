---
type StatusColor = "toxic" | "amber" | "magenta" | "cyan" | "dim" | "yellow" | "pink";

interface Props {
  index: string;
  title: string;
  status: string;
  statusColor?: StatusColor;
  href?: string;
  external?: boolean;
  disabled?: boolean;
}

const {
  index,
  title,
  status,
  statusColor = "cyan",
  href,
  external = false,
  disabled = false,
} = Astro.props;

const colorClass: Record<StatusColor, string> = {
  toxic: "text-toxic",
  amber: "text-amber",
  magenta: "text-magenta",
  cyan: "text-cyan",
  dim: "text-dim",
  yellow: "text-yellow",
  pink: "text-pink",
};

const statusText = colorClass[statusColor];
const Tag = disabled ? "div" : "a";
---

<Tag
  href={disabled ? undefined : href}
  target={external && !disabled ? "_blank" : undefined}
  rel={external && !disabled ? "noreferrer noopener" : undefined}
  class:list={[
    "project-card group block relative bg-deck p-5 transition-all duration-200 sm:p-7 overflow-hidden",
    disabled
      ? "opacity-60 cursor-not-allowed border border-dashed border-dim/40"
      : "border border-rack hover:-translate-y-[2px] hover:border-cyan",
  ]}
>
  <span class="project-card__chevrons" aria-hidden="true"></span>
  <span class="project-card__sweep" aria-hidden="true"></span>

  <div class="relative flex items-start justify-between gap-4">
    <div class="flex items-baseline gap-3">
      <span class="font-hud text-xl text-yellow">[{index}]</span>
      <h3 class="project-card__title font-ui text-lg font-bold uppercase tracking-[0.08em] text-bone sm:text-2xl">
        {title}
      </h3>
    </div>
    <span class:list={["font-hud text-base whitespace-nowrap", statusText]}>
      [ {status} ]
    </span>
  </div>

  <p class="relative mt-4 max-w-2xl font-ui text-sm leading-relaxed text-haze sm:text-base">
    <slot />
  </p>

  {
    !disabled && (
      <span class="relative mt-5 inline-flex items-center gap-2 font-hud text-base text-cyan transition-transform group-hover:translate-x-1">
        <span aria-hidden="true">▸</span>
        <span>{external ? "open external" : "open"}</span>
      </span>
    )
  }
</Tag>

<style>
  .project-card {
    isolation: isolate;
  }

  .project-card:hover {
    box-shadow:
      0 0 0 1px var(--color-cyan),
      0 0 32px rgba(0, 240, 255, 0.28),
      inset 0 0 0 1px rgba(0, 240, 255, 0.18);
  }

  /* Chevron stripe top-right (CP2077 detail) */
  .project-card__chevrons {
    position: absolute;
    top: 0;
    right: 0;
    width: 80px;
    height: 4px;
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-yellow) 0 6px,
      var(--color-void) 6px 12px
    );
    background-size: 36px 36px;
    opacity: 0.85;
    pointer-events: none;
    animation: chevron-drift 4s linear infinite;
  }

  @keyframes chevron-drift {
    from { background-position: 0 0; }
    to   { background-position: 36px 0; }
  }

  /* Hover sweep — bright cyan diagonal pass over the card */
  .project-card__sweep {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 30%,
      rgba(0, 240, 255, 0.18) 50%,
      transparent 70%
    );
    transform: translateX(-110%);
    transition: transform 0.6s ease-out;
    pointer-events: none;
  }

  .project-card:hover .project-card__sweep {
    transform: translateX(110%);
  }

  /* Title RGB-split on hover */
  .project-card:hover .project-card__title {
    text-shadow:
      2px 0 var(--color-magenta),
      -2px 0 var(--color-cyan);
    animation: card-title-glitch 0.45s steps(5);
  }

  @keyframes card-title-glitch {
    0%   { transform: translate(0, 0); }
    20%  { transform: translate(-1px, 1px); }
    40%  { transform: translate(2px, -1px); }
    60%  { transform: translate(-1px, -1px); }
    80%  { transform: translate(1px, 1px); }
    100% { transform: translate(0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card__chevrons,
    .project-card__sweep,
    .project-card:hover .project-card__title {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
