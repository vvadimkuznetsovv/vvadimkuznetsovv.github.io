---
type StatusColor = "toxic" | "amber" | "magenta" | "cyan" | "dim" | "yellow" | "pink";

interface Props {
  index: string;
  title: string;
  status: string;
  statusColor?: StatusColor;
  href?: string;
  external?: boolean;
  disabled?: boolean;
}

const {
  index,
  title,
  status,
  statusColor = "cyan",
  href,
  external = false,
  disabled = false,
} = Astro.props;

const colorClass: Record<StatusColor, string> = {
  toxic: "text-toxic neon-pulse",
  amber: "text-amber",
  magenta: "text-magenta neon-pulse neon-pulse--magenta",
  cyan: "text-cyan neon-pulse neon-pulse--cyan",
  dim: "text-dim",
  yellow: "text-yellow neon-pulse",
  pink: "text-pink",
};

const Tag = disabled ? "div" : "a";
const isLink = !disabled;
---

<Tag
  href={disabled ? undefined : href}
  target={external && !disabled ? "_blank" : undefined}
  rel={external && !disabled ? "noreferrer noopener" : undefined}
  class:list={[
    "notched group",
    isLink && "notched--link",
    disabled && "notched--dim",
  ]}
  style="--notch: 26px;"
>
  <div class="notched__body">
    <span class="notched__edge" aria-hidden="true"></span>
    <span class="notched__sweep" aria-hidden="true"></span>
    <span class="notched__chevrons" aria-hidden="true"></span>

    <div class="relative flex items-start justify-between gap-4">
      <div class="flex items-baseline gap-3">
        <span class="font-hud text-2xl text-yellow drop-shadow-[0_0_8px_var(--color-yellow)]">
          [{index}]
        </span>
        <h3 class="project-card__title font-ui text-lg font-bold uppercase tracking-[0.08em] text-bone sm:text-2xl">
          {title}
        </h3>
      </div>
      <span class:list={["font-hud text-base whitespace-nowrap", colorClass[statusColor]]}>
        [ {status} ]
      </span>
    </div>

    <p class="relative mt-4 max-w-2xl font-ui text-sm leading-relaxed text-haze sm:text-base">
      <slot />
    </p>

    {
      !disabled && (
        <span class="relative mt-5 inline-flex items-center gap-2 font-hud text-base text-cyan transition-transform group-hover:translate-x-1">
          <span aria-hidden="true">▸</span>
          <span class="neon-pulse neon-pulse--cyan">{external ? "open external" : "open"}</span>
        </span>
      )
    }
  </div>
</Tag>

<style>
  /* Title RGB-split on hover — desktop only */
  @media (hover: hover) {
    .notched--link:hover .project-card__title {
      text-shadow:
        2px 0 var(--color-magenta),
        -2px 0 var(--color-cyan);
    }
  }
</style>
