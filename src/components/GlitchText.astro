---
interface Props {
  text: string;
  class?: string;
  decrypt?: boolean;
  ambient?: boolean;
}

const {
  text,
  class: className = "",
  decrypt = false,
  ambient = true,
} = Astro.props;
---

<span
  class:list={[
    "glitch",
    { "glitch--ambient": ambient, "glitch--decrypt": decrypt },
    className,
  ]}
  data-text={text}
  data-decrypt-target={decrypt ? text : undefined}
>
  {text}
</span>

<style>
  .glitch {
    position: relative;
    display: inline-block;
    line-height: inherit;
    isolation: isolate;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    width: 100%;
    pointer-events: none;
    opacity: 0;
  }

  .glitch::before {
    color: var(--color-cyan);
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.55);
  }

  .glitch::after {
    color: var(--color-magenta);
    text-shadow: 0 0 10px rgba(255, 43, 214, 0.55);
  }

  /* ---------- ambient (always-on, subtle, brief flashes) ---------- */
  .glitch--ambient::before {
    animation: ambient-a 7s ease-in-out infinite;
  }
  .glitch--ambient::after {
    animation: ambient-b 7s ease-in-out infinite;
  }

  @keyframes ambient-a {
    0%, 92%, 100%      { opacity: 0; transform: translate(0, 0); clip-path: inset(0); }
    93%                { opacity: 0.7; transform: translate(-2px, 0); clip-path: inset(30% 0 60% 0); }
    94%                { opacity: 0.55; transform: translate(2px, -1px); clip-path: inset(65% 0 10% 0); }
    95%                { opacity: 0.4; transform: translate(-1px, 1px); clip-path: inset(10% 0 75% 0); }
    96%                { opacity: 0; }
  }

  @keyframes ambient-b {
    0%, 92%, 100%      { opacity: 0; transform: translate(0, 0); clip-path: inset(0); }
    93%                { opacity: 0.55; transform: translate(2px, 1px); clip-path: inset(50% 0 20% 0); }
    94%                { opacity: 0.7; transform: translate(-2px, 0); clip-path: inset(15% 0 60% 0); }
    95%                { opacity: 0.45; transform: translate(1px, -1px); clip-path: inset(70% 0 5% 0); }
    96%                { opacity: 0; }
  }

  /* ---------- hover (strong) ---------- */
  .glitch:hover::before {
    opacity: 0.95;
    animation: glitch-a 480ms steps(6) infinite !important;
  }
  .glitch:hover::after {
    opacity: 0.95;
    animation: glitch-b 480ms steps(6) infinite !important;
  }

  @keyframes glitch-a {
    0%   { transform: translate(0, 0);    clip-path: inset(20% 0 60% 0); }
    16%  { transform: translate(-3px, 1px); clip-path: inset(60% 0 20% 0); }
    32%  { transform: translate(3px, -1px); clip-path: inset(40% 0 40% 0); }
    48%  { transform: translate(-2px, 1px); clip-path: inset(80% 0 5% 0); }
    64%  { transform: translate(2px, 0);    clip-path: inset(10% 0 70% 0); }
    80%  { transform: translate(-3px, 0);   clip-path: inset(30% 0 30% 0); }
    100% { transform: translate(0, 0);      clip-path: inset(20% 0 60% 0); }
  }

  @keyframes glitch-b {
    0%   { transform: translate(0, 0);    clip-path: inset(70% 0 10% 0); }
    16%  { transform: translate(3px, -1px); clip-path: inset(10% 0 80% 0); }
    32%  { transform: translate(-3px, 1px); clip-path: inset(50% 0 30% 0); }
    48%  { transform: translate(2px, -1px); clip-path: inset(20% 0 50% 0); }
    64%  { transform: translate(-2px, 0);   clip-path: inset(60% 0 20% 0); }
    80%  { transform: translate(3px, 1px);  clip-path: inset(40% 0 40% 0); }
    100% { transform: translate(0, 0);      clip-path: inset(70% 0 10% 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch--ambient::before,
    .glitch--ambient::after,
    .glitch:hover::before,
    .glitch:hover::after {
      animation: none !important;
      opacity: 0 !important;
    }
  }
</style>
